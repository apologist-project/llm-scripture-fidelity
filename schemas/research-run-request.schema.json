      "additionalProperties": false,
      "properties": {
        "model": {
          "title": "Model",
          "type": "string"
        },
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "supports_temperature": {
          "default": true,
          "title": "Supports Temperature",
          "type": "boolean"
        }
      },
      "required": [
        "provider",
        "model"
      ],
      "title": "ModelModel",
      "type": "object"
    },
    "ReferenceModel": {
      "additionalProperties": false,

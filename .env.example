# ---------------------------------------------------------------------------
# Study variant configuration (JSON arrays)
# Copy this file to .env and fill in your API keys.
# ---------------------------------------------------------------------------

# Scripture references to test. "type" is a free-form label used for grouping
# in reports (e.g. well_known_single, obscure_single, range, chapter).
# REFERENCES='[
  {"ref": "John 3:16",         "type": "well_known_single"},
  {"ref": "Genesis 1:1",       "type": "well_known_single"},
  {"ref": "2 Timothy 4:13",    "type": "obscure_single"},
  {"ref": "1 Chronicles 2:47", "type": "obscure_single"},
  {"ref": "Romans 8:31-39",    "type": "range"},
  {"ref": "Proverbs 13:1-10",  "type": "range"},
  {"ref": "1 Peter 3",         "type": "chapter"},
  {"ref": "Psalm 117",         "type": "chapter"}
]'

# Quotation methods: unassisted | rag | tool_call | output_buffer
METHODS='["unassisted", "rag", "tool_call", "web_search", "output_buffer"]'

# Bible translations. "api" selects the provider client:
#   helloao    - AO Lab Free Use Bible API (free, no key)
#   api_bible  - API.Bible (requires API_BIBLE_API_KEY)
#   youversion - YouVersion Platform (requires YOUVERSION_APP_KEY)
# "api_bible_id" is the provider-specific identifier for the translation.
# Use `scripture-fidelity list-bibles --api <provider>` to discover IDs.
TRANSLATIONS='[
  {"id": "NIV", "name": "New International Version", "language": "eng", "api": "api_bible", "api_bible_id": "78a9f6124f344018-01"},
  {"id": "KJV", "name": "King James Version", "language": "eng", "api": "api_bible",   "api_bible_id": "a6aee10bb058511c-01"},
  {"id": "NASB1995", "name": "New American Standard 1995", "language": "eng", "api": "api_bible", "api_bible_id": "b8ee27bcd1cae43a-01"},
  {"id": "BSB", "name": "Berean Standard Bible", "language": "eng", "api": "ao_lab", "api_bible_id": "BSB"},
  {"id": "WEBU", "name": "World English Bible Updated", "language": "eng", "api": "ao_lab", "api_bible_id": "eng_webu"},
  {"id": "ASV", "name": "American Standard Version", "language": "eng", "api": "ao_lab", "api_bible_id": "eng_asv"},
  {"id": "CCB", "name": "Chinese Contemporary Bible 2022 (Simplified)", "language": "zho", "api": "youversion", "api_bible_id": "36"},
  {"id": "BES", "name": "La Biblia en Español Sencillo", "language": "spa", "api": "ao_lab", "api_bible_id": "spa_bes"},
  {"id": "LSG", "name": "French Louis Segond 1910 Bible", "language": "fra", "api": "ao_lab", "api_bible_id": "fra_lsg"},
  {"id": "L12", "name": "German Luther Bible 1912", "language": "deu", "api": "ao_lab", "api_bible_id": "deu_l12"},
  {"id": "IRV", "name": "Hindi Indian Revised Version Bible", "language": "hin", "api": "ao_lab", "api_bible_id": "HINIRV"},
  {"id": "NAV", "name": "New Arabic Version", "language": "ara", "api": "youversion", "api_bible_id": "101"},
  {"id": "NVI", "name": "Nova Versão Internacional - Português", "language": "por", "api": "youversion", "api_bible_id": "129"},
  {"id": "IRV", "name": "Urdu IRV Bible", "language": "urd", "api": "ao_lab", "api_bible_id": "urd_irv"},
  {"id": "SYN", "name": "Russian Synodal Bible", "language": "rus", "api": "ao_lab", "api_bible_id": "rus_syn"},
  {"id": "OCV", "name": "Open Bengali Contemporary Version Bible", "language": "ben", "api": "ao_lab", "api_bible_id": "ben_ocv"}
]'



# Prompt languages (ISO 639-3): eng | zho (crossed with every translation)
LANGUAGES='["eng", "zho", "spa", "fra", "deu", "hin", "ara", "por", "urd", "rus", "ben"]'

# Models. "provider" maps to an Inspect AI provider prefix:
#   openai | anthropic | google | together | xai | mockllm (testing)
MODELS='[
  {"provider": "openai",    "model": "gpt-5.4"},
  {"provider": "openai",    "model": "gpt-5.4-mini"},
  {"provider": "anthropic", "model": "claude-sonnet-4-6"},
  {"provider": "anthropic", "model": "claude-haiku-4-5"},
  {"provider": "xai",       "model": "grok-4.3-latest"},
  {"provider": "xai",       "model": "grok-4-fast-non-reasoning"},
  {"provider": "google",    "model": "gemini-3.1-pro-preview"},
  {"provider": "google",    "model": "gemini-3.5-flash"},
  {"provider": "together",  "model": "deepseek-ai/DeepSeek-V4-Pro"},
  {"provider": "together",  "model": "Qwen/Qwen3.7-Max"}
]'

# Sampling temperatures.
TEMPERATURES='[0.0, 0.25, 0.5, 0.75, 1.0]'

# Optional (default [1]): reference set sizes. Sizes > 1 chunk the
# REFERENCES list (in order) into sets of that size; each set is requested
# in a single prompt, testing whether models handle every reference (e.g.
# one get_passage call per reference).
REFERENCE_SET_SIZES='[1, 3]'

# ---------------------------------------------------------------------------
# Provider API keys (never commit real values)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=xxx
ANTHROPIC_API_KEY=xxx
GOOGLE_API_KEY=xxx
TOGETHER_API_KEY=xxx
XAI_API_KEY=xxx

# Bible API keys
API_BIBLE_API_KEY=xxx
YOUVERSION_API_KEY=xxx

# Parallel.ai Search API key (required for the web_search method)
PARALLEL_API_KEY=xxx

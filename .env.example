# ---------------------------------------------------------------------------
# Study variant configuration (JSON arrays)
# Copy this file to .env and fill in your API keys.
# ---------------------------------------------------------------------------

# Scripture references to test. "type" is a free-form label used for grouping
# in reports (e.g. well_known_single, obscure_single, range, chapter).
REFERENCES='[
  {"ref": "John 3:16",       "type": "well_known_single"},
  {"ref": "Genesis 1:1",     "type": "well_known_single"},
  {"ref": "Obadiah 1:12",    "type": "obscure_single"},
  {"ref": "Nahum 2:9",       "type": "obscure_single"},
  {"ref": "Romans 8:38-39",  "type": "range"},
  {"ref": "Psalm 117",       "type": "chapter"}
]'

# Quotation methods: unassisted | rag | tool_call | output_buffer
METHODS='["unassisted", "rag", "tool_call", "output_buffer"]'

# Bible translations. "api" selects the provider client:
#   helloao    - AO Lab Free Use Bible API (free, no key)
#   api_bible  - API.Bible (requires API_BIBLE_API_KEY)
#   youversion - YouVersion Platform (requires YOUVERSION_APP_KEY)
# "api_bible_id" is the provider-specific identifier for the translation.
# Use `scripture-fidelity list-bibles --api <provider>` to discover IDs.
TRANSLATIONS='[
  {"id": "BSB", "name": "Berean Standard Bible", "language": "eng", "api": "helloao",   "api_bible_id": "BSB"},
  {"id": "KJV", "name": "King James Version",    "language": "eng", "api": "api_bible", "api_bible_id": "de4e12af7f28f599-02"},
  {"id": "CUV", "name": "Chinese Union Version", "language": "zho", "api": "helloao",   "api_bible_id": "cmn_cuv"}
]'

# Prompt languages (ISO 639-3): eng | zho (crossed with every translation)
LANGUAGES='["eng"]'

# Models. "provider" maps to an Inspect AI provider prefix:
#   openai | anthropic | google | together | grok | mockllm (testing)
MODELS='[
  {"provider": "openai",    "model": "gpt-4o-mini"},
  {"provider": "anthropic", "model": "claude-3-5-haiku-latest"},
  {"provider": "google",    "model": "gemini-2.5-flash"}
]'

# Sampling temperatures.
TEMPERATURES='[0.0]'

# ---------------------------------------------------------------------------
# Provider API keys (never commit real values)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TOGETHER_API_KEY=
XAI_API_KEY=

# Bible API keys
API_BIBLE_API_KEY=
YOUVERSION_APP_KEY=

# Keep the build context small and never ship secrets or local state.
.git
.gitignore
.github

# Secrets and local env
.env
.envrc

# Python caches / build artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/

# Test / tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
tests/

# Local run outputs and passage cache
results/
.cache/

# Editor / OS
.idea/
.vscode/
.DS_Store

# Docs (not needed at runtime)
docs/
